generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PadAuditAction {
  CREATED
  VIEWED
  UPDATED
  SOFT_DELETED
  RESTORED
  HARD_DELETED
  RATE_LIMITED
}

model Pad {
  id           String    @id @default(uuid())
  slug         String    @unique
  content      String    @default("")
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt    DateTime? @db.Timestamptz(3)
  lastViewedAt DateTime? @db.Timestamptz(3)
  legalHold    Boolean   @default(false)

  auditLogs    PadAuditLog[]

  @@index([deletedAt])
  @@index([updatedAt])
  @@index([lastViewedAt])
  @@index([legalHold])
}

model PadAuditLog {
  id              String         @id @default(uuid())
  padId           String?
  slug            String
  action          PadAuditAction
  contentHash     String?
  contentSnapshot String?
  ipAddress       String?
  userAgent       String?
  requestId       String?
  metadata        Json?
  createdAt       DateTime       @default(now()) @db.Timestamptz(3)

  pad             Pad?           @relation(fields: [padId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([action])
  @@index([createdAt])
  @@index([ipAddress])
  @@index([padId])
}